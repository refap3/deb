#!/usr/bin/env bash
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REBOOT_SCRIPT_PATH="$HOME/reboot_daily.sh"
ROOT_CRON_JOB="0 2 * * * /sbin/reboot"

setup_daily_reboot() {
    echo "Creating reboot script at $REBOOT_SCRIPT_PATH..."
    cat <<'EOF' > "$REBOOT_SCRIPT_PATH"
#!/bin/sh
/sbin/reboot
EOF
    chmod +x "$REBOOT_SCRIPT_PATH"

    echo "Adding cron job to root's crontab..."
    (sudo crontab -l 2>/dev/null | grep -v "/sbin/reboot"; echo "$ROOT_CRON_JOB") | sudo crontab -

    echo "Done. Pi will reboot at 2:00 AM daily."
}

remove_daily_reboot() {
    if [ -f "$REBOOT_SCRIPT_PATH" ]; then
        rm -f "$REBOOT_SCRIPT_PATH"
        echo "Removed $REBOOT_SCRIPT_PATH."
    else
        echo "Reboot script not found at $REBOOT_SCRIPT_PATH."
    fi

    (sudo crontab -l 2>/dev/null | grep -v "/sbin/reboot") | sudo crontab -
    echo "Daily reboot removed."
}


while true; do
    if [[ -n "$1" ]]; then
        choice="$1"
        set --
        one_shot=true
    else
        echo "Menu:"
        echo "1. Install SSH keys"
        echo "2. Enable login with KEY only"
        echo "3. Enable login with password"
        echo "4. Remove SSH password warning"
        echo "5. Enable sudo (Debian)"
        echo "6. Enable sudo (Ubuntu)"
        echo "7. Github credential helper"
        echo "8. Install Docker stack (docker / compose / portainer)"
        echo "9. Manage Daily Reboot (setup or remove)"
        echo "a. Install alias (shell dotfiles)"
        echo "b. Disk Speed Test"
        echo "c. CPU Speed Test"
        echo "d. Uninstall Docker (full cleanup)"
        echo "e. Uninstall full bootstrap (Docker + alias) — for re-testing --full"
        echo "0. Exit"
        read -p "Enter your choice: " choice
    fi

    case $choice in
        1)
            echo "Install SSH keys ..."
            "${SCRIPT_DIR}/patch_sshkeys"
            ;;
        2)
            echo "Login key only ..."
            "${SCRIPT_DIR}/patch_ssh_only"
            ;;
        3)
            echo "Login password ..."
            "${SCRIPT_DIR}/patch_ssh_password"
            ;;
        4)
            echo "Removing SSH password warning ..."
            "${SCRIPT_DIR}/patch_remove_password_warning"
            ;;
        5)
            echo "Sudo on ..."
            "${SCRIPT_DIR}/patch_sudo"
            ;;
        6)
            echo "UBUNTU sudo on ..."
            "${SCRIPT_DIR}/ub_patch_sudo"
            ;;
        7)
            echo "Setting up git credential helper ..."
            git config --global credential.helper store
            echo "Done. Next push will prompt for credentials and cache them."
            ;;
        8)
            echo "Installing Docker ..."
            "${SCRIPT_DIR}/install_docker"
            echo "Docker installed. Log out and back in for group to apply, then:"
            echo "  cd ${SCRIPT_DIR} && docker-compose up -d"
            ;;
        9)
            echo "Manage Daily Reboot:"
            echo "1. Set up daily reboot at 2:00 AM"
            echo "2. Remove daily reboot"
            echo "3. Check daily reboot status"
            read -p "Enter your choice: " reboot_choice
            case $reboot_choice in
                1)
                    setup_daily_reboot
                    ;;
                2)
                    remove_daily_reboot
                    ;;
                3)
                    echo "=== Root crontab (correct) ==="
                    sudo crontab -l 2>/dev/null | grep -i reboot || echo "  (no reboot entry in root crontab)"
                    echo "=== User crontab (should be empty for reboot) ==="
                    crontab -l 2>/dev/null | grep -i reboot && echo "  WARNING: old broken entry still present — run option 2 then 1 to fix" || echo "  (clean)"
                    echo "=== Reboot script ==="
                    if [ -f "$REBOOT_SCRIPT_PATH" ]; then
                        echo "  Found: $REBOOT_SCRIPT_PATH"
                        cat "$REBOOT_SCRIPT_PATH"
                    else
                        echo "  Not found at $REBOOT_SCRIPT_PATH"
                    fi
                    echo "=== Last 5 reboots (from wtmp) ==="
                    if command -v last >/dev/null 2>&1; then
                        last reboot -n 5 | grep -v "^$\|^wtmp" || echo "  (no reboot entries found)"
                    else
                        echo "  'last' command not available"
                    fi
                    ;;
                *)
                    echo "Invalid choice. Returning to main menu."
                    ;;
            esac
            ;;
          a)
              echo "Installing alias (shell dotfiles) ..."
              git clone https://github.com/refap3/alias ~/alias
              ~/alias/deploy.sh
              echo "Done. Run: source ~/.zshrc"
              ;;
          b)
              "${SCRIPT_DIR}/disk_speed_test"
              ;;
          c)
              "${SCRIPT_DIR}/cpu_speed_test"
              ;;
          d)
              echo "Uninstalling Docker..."
              "${SCRIPT_DIR}/uninstall_docker"
              ;;
          e)
              echo "Uninstalling full bootstrap (Docker + alias)..."
              "${SCRIPT_DIR}/uninstall_full"
              ;;
          0|'')
            echo "Exiting..."
            break
            ;;
        *)
            echo "Invalid choice. Please try again."
            ;;
    esac

    [[ "${one_shot:-false}" == true ]] && break
    echo
done
